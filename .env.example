# 못그린 영화퀴즈 — 환경변수 예시
# 이 파일을 .env 로 복사한 뒤, 실제 키를 입력하세요.
# (둘 다 선택사항입니다. 키가 없으면 placeholder 데이터가 그대로 사용됩니다.)

# TMDB API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb API key — https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# Used by: npm run gen-openai (이미지 생성)
# ⚠️  채팅·코드·git 어디에도 절대 붙여넣지 말고, 이 .env 파일에만 두세요.
OPENAI_API_KEY=
# 선택 — 모델/크기/동시성 (기본값 사용 시 비워두세요)
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_CONCURRENCY=2
